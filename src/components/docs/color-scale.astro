---

<div class='not-prose grid grid-cols-6 gap-3 sm:grid-cols-11'>
  {
    shades.map((shade) => (
      <ColorSwatch
        bg={values[name][shade]}
        label={`${shade}`}
        textColor={textColors[name][shade]}
      />
    ))
  }
</div>
