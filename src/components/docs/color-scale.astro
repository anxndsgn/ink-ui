    900: "oklch(0.26461 0.055 41.5)",
    950: "oklch(0.21016 0.04 41.5)",
  },
};

const textColors: Record<
  Props["name"],
  Record<(typeof shades)[number], string>
> = {
  gray: {
    50: "text-gray-900",
    100: "text-gray-900",
    200: "text-gray-900",
    300: "text-gray-900",
    400: "text-gray-900",
    500: "text-white",
    600: "text-white",
    700: "text-white",
    800: "text-white",
    900: "text-white",
    950: "text-white",
  },
  red: {
    50: "text-red-900",
    100: "text-red-900",
    200: "text-red-900",
    300: "text-red-900",
    400: "text-white",
    500: "text-white",
    600: "text-white",
    700: "text-white",
    800: "text-white",
    900: "text-white",
    950: "text-white",
  },
  orange: {
    50: "text-orange-900",
    100: "text-orange-900",
    200: "text-orange-900",
    300: "text-orange-900",
    400: "text-white",
