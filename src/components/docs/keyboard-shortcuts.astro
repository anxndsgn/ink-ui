---
interface Shortcut {
  keys: string[];
  description: string;
}

interface Props {
  shortcuts: Shortcut[];
}

const { shortcuts } = Astro.props;
---

<div class='my-4 space-y-2'>
  {
    shortcuts.map(({ keys, description }) => (
      <div class='flex items-center gap-3'>
        <span class='flex items-center gap-1'>
          {keys.map((key, i) => (
            <>
              <kbd class='inline-flex items-center justify-center rounded border border-border bg-muted px-1.5 py-0.5 text-xs font-medium min-w-6'>
                {key}
              </kbd>
              {i < keys.length - 1 && (
                <span class='text-muted-foreground text-xs'>+</span>
              )}
            </>
          ))}
        </span>
        <span class='text-muted-foreground'>{description}</span>
      </div>
    ))
  }
</div>
